{
  "name": "euronews-pt-reading-lab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
      "dev": "pnpm --filter @euronews/web dev",
      "dev:web": "pnpm --filter @euronews/web dev",
      "dev:worker": "pnpm --filter @euronews/worker dev",
      "dev:all": "pnpm -r --parallel --if-present dev",
      "db:migrate:local": "pnpm --filter @euronews/worker db:migrate:local",
      "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
